{
  "name": "{{dashCase name}}",
  "version": "1.0.0",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "build": "npm run build:{{env}}",
    "build:development": "echo 'Dev build (no minify)' && npm run prepare",
    "build:staging": "echo 'Staging build (optional minify)' && npm run prepare",
    "build:production": "npm prune --omit=dev && npx terser src/server.js -o dist/server.min.js",
    "prepare": "husky install",
    "generate": "plop",
    "audit": "npm audit --omit=dev",
    "mutate": "stryker run",
    "test": "jest",
    "test:all": "npm run test -- --coverage && npm run mutate",
    "sonar": "sonar-scanner",
    "lint": "eslint . --ext .js",
    "format": "prettier --write ."
  },
  "dependencies": {
    "dd-trace": "^3.0.0",
    "dotenv": "^16.0.0",
    "express": "^4.18.2",
    "pino": "^8.0.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^4.6.3",
    "consul": "^0.40.0",
    "@aws-sdk/client-sns": "^3.500.0",
    "jsonwebtoken": "^9.0.0",
    "jwks-rsa": "^3.1.1",
    "helmet": "^7.0.0",
    "rate-limiter-flexible": "^2.4.0",
    "ioredis": "^5.3.2",
    "zod": "^3.22.2",
    "uuid": "^9.0.0",
    "p-retry": "^5.0.0"
  },
  "devDependencies": {
    "jest": "^29.0.0",
    "nodemon": "^3.0.0",
    "husky": "^8.0.0",
    "lint-staged": "^14.0.0",
    "@commitlint/cli": "^17.0.0",
    "@commitlint/config-conventional": "^17.0.0",
    "plop": "^3.0.0",
    "supertest": "^6.3.3",
    "@pact-foundation/pact": "^11.1.1",
    "@stryker-mutator/core": "^6.2.0"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "description": "{{properCase name}} microservice",
  "boilerplateVersion": "1.0.0"
}