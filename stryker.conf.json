{
  "$schema": "https://raw.githubusercontent.com/stryker-mutator/stryker/master/packages/api/schema/stryker-schema.json",
  "mutator": "javascript",
  "packageManager": "npm",
  "reporters": [
    "html",
    "clear-text",
    "progress"
  ],
  "testRunner": "jest",
  "coverageAnalysis": "off",
  "jest": {
    "projectType": "custom",
    "configFile": "jest.config.js"
  },
  "ignorePatterns": [
    "src/config/swagger.js",
    "src/server.js"
  ]
}